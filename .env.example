# DeFi Academy — Umgebungsvariablen-Vorlage.
#
# Echte Keys gehoeren NICHT ins Repo — kopiere diese Datei nach `.env`
# (ist per .gitignore ausgeschlossen) und trage dort deine Werte ein.
#
# Variablen werden nicht automatisch geladen — setze sie in der Shell
# (PowerShell: $env:ELEVENLABS_API_KEY = "..."), via dotenv-Wrapper oder
# im CI/CD als Secrets.

# --- Next.js / Plattform -----------------------------------------------------

# Optional: Akademie-Inhalte aus anderem Ordner (sonst: content/modules/ im Repo)
# Die Variable heisst aus Gruenden der Rueckwaertskompatibilitaet weiter
# DEFI_CURRICULUM_PATH — der Pfad zeigt auf Module der DeFi Akademie.
# DEFI_CURRICULUM_PATH=C:\Pfad\zu\Module

# Oeffentliche Site-URL (metadataBase / OG) — auf GitHub Pages in CI gesetzt; lokal optional:
# NEXT_PUBLIC_SITE_URL=https://noahdeitmerg-svg.github.io/Defi-Academy
# SITE_URL=https://noahdeitmerg-svg.github.io/Defi-Academy

# --- ElevenLabs (scripts/generate-voice.js, scripts/render-course.js) --------
ELEVENLABS_API_KEY=sk_xxxxx
ELEVENLABS_MODEL=eleven_multilingual_v3
ELEVENLABS_VOICE=Florian
# Optional: direkte Voice-ID (ueberspringt die Namensaufloesung via /v1/voices)
# ELEVENLABS_VOICE_ID=
# Optional: Voice-Settings (defaults 0.4 / 0.8 / 0.2 fuer v3-Pipeline)
# ELEVENLABS_STABILITY=0.4
# ELEVENLABS_SIMILARITY=0.8
# ELEVENLABS_STYLE=0.2
# Optional: MP3-Enhancement nach TTS ausschalten (nur Kopie): VOICE_ENHANCE=0

# --- Gamma (scripts/render-course.js) ----------------------------------------
# Ohne Key laeuft render-course im Stub-Modus und spiegelt slides_prompt.txt
# zur manuellen Verarbeitung in assets-input/<id>/.
# GAMMA_API_KEY=
# GAMMA_API_URL=https://api.gamma.app/v1/generations
