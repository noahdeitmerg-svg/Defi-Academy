# Ensure consistent line endings across Windows, macOS and Linux.
# Git will normalize text files to LF on commit and check them out with
# native line endings on Windows (CRLF) / Unix (LF).
* text=auto eol=lf

# Explicit text files (force LF)
*.md        text eol=lf
*.json      text eol=lf
*.jsonl     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf
*.txt       text eol=lf

# Binary files — never diff, never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.svg       binary
*.mp3       binary
*.mp4       binary
*.webm      binary
*.pdf       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
