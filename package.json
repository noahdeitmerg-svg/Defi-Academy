{
  "name": "defi-academy",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/noahdeitmerg-svg/Defi-Academy.git"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate:content": "node ./node_modules/tsx/dist/cli.mjs scripts/validate-content.ts",
    "validate-lessons": "node scripts/validate-lessons.js",
    "render-course": "node scripts/render-course.js",
    "pilot-render": "node scripts/pilot-render.js",
    "generate:voice": "node scripts/generate-voice.js",
    "generate:slides": "node scripts/generate-slides.js",
    "prepare:assets": "node scripts/create-lesson-asset-folders.js",
    "render:pilot": "npm run generate:slides && npm run generate:voice && node scripts/render-batch.js --limit 5 --parallel 1",
    "render:course": "npm run generate:slides && npm run generate:voice && node scripts/render-batch.js --parallel 2",
    "verify": "npm run validate:content && npm run lint && npm run typecheck && npm run build",
    "import:modules": "node ./node_modules/tsx/dist/cli.mjs scripts/import-modules.ts",
    "check": "npm run verify"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^15.3.1",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/mdx": "^2.0.13",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.1",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
