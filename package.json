{
  "name": "defi-academy",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/noahdeitmerg-svg/Defi-Academy.git"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate:content": "node ./node_modules/tsx/dist/cli.mjs scripts/validate-content.ts",
    "validate-lessons": "node scripts/validate-lessons.js",
    "pipeline:sync-assets": "npm run generate-assets && npm run prepare:assets -- --copy-prompt",
    "render:orchestrator": "node scripts/render-course.js",
    "pilot-render": "node scripts/pilot-render.js",
    "generate:voice": "node scripts/generate-voice.js",
    "generate:slides": "node scripts/generate-slides.js",
    "prepare:assets": "node scripts/create-lesson-asset-folders.js",
    "render:pilot": "npm run generate:slides && npm run generate:voice && node scripts/render-batch.js --generator-output generated-assets --limit 5 --parallel 1",
    "render:course": "npm run generate:slides && npm run generate:voice && node scripts/render-batch.js --generator-output generated-assets --parallel 2",
    "generate-assets": "node scripts/generate-all-assets.js",
    "collect-prompts": "node scripts/collect-prompts.js",
    "check-assets": "node scripts/check-assets.js",
    "render-videos": "node scripts/render-all-videos.js",
    "publish-videos": "node scripts/publish-videos.js",
    "videos:module": "node scripts/batch-module-videos.js",
    "split-modules": "node scripts/split-modules.js",
    "sync:brand": "node brand/sync-to-theme.js",
    "academy-build": "npm run sync:brand && npm run generate-assets && npm run collect-prompts",
    "verify": "npm run validate:content && npm run lint && npm run typecheck && npm run build",
    "import:modules": "node ./node_modules/tsx/dist/cli.mjs scripts/import-modules.ts",
    "check": "npm run verify",
    "test:voice-pipeline": "node --test pipeline/voice/tests/voice_pipeline.test.js",
    "test:tier-policy": "node --import tsx --test lib/tier/tierPolicy.test.ts",
    "f7:redirects": "node scripts/generate-f7-redirects.js",
    "split:modul-17": "node scripts/split-modul-17.mjs",
    "export:takeaways-input": "node ./node_modules/tsx/dist/cli.mjs scripts/export-takeaways-input.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "@supabase/supabase-js": "^2.103.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "^15.3.1",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.1",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
