{
  "name": "DeFi Academy Video Timing Standard",
  "version": "1.0.0",
  "description": "Standardisiertes Timing fuer den 9-Sektionen-Aufbau jeder Lektion. Dauern sind Zielwerte in Sekunden.",

  "video_length": {
    "minimum_seconds": 300,
    "target_seconds": 480,
    "maximum_seconds": 600,
    "notes": "5-10 Minuten pro Lektion. Zielwert 8 Minuten."
  },

  "fps": 30,

  "structure": [
    {
      "section": "intro",
      "order": 1,
      "target_seconds": 12,
      "min_seconds": 8,
      "max_seconds": 15,
      "slide_count": 0,
      "uses_scene": "intro-scene",
      "voice": false,
      "notes": "Logo-Reveal, keine Narration. Sound-Sting optional."
    },
    {
      "section": "lesson_title",
      "order": 2,
      "target_seconds": 15,
      "min_seconds": 10,
      "max_seconds": 20,
      "slide_count": 1,
      "uses_scene": "slide-template",
      "voice": true,
      "notes": "Titel der Lektion + kurze Einordnung (1-2 Saetze Narration)."
    },
    {
      "section": "concept",
      "order": 3,
      "target_seconds": 75,
      "min_seconds": 50,
      "max_seconds": 90,
      "slide_count": 1,
      "uses_scene": "slide-template",
      "voice": true,
      "notes": "Grundbegriff / Definition. Erklaerung was das Thema ist."
    },
    {
      "section": "mechanism",
      "order": 4,
      "target_seconds": 90,
      "min_seconds": 70,
      "max_seconds": 110,
      "slide_count": 1,
      "uses_scene": "slide-template",
      "voice": true,
      "notes": "Wie funktioniert es mechanisch? Formeln, Schritte, Logik."
    },
    {
      "section": "system_architecture",
      "order": 5,
      "target_seconds": 70,
      "min_seconds": 50,
      "max_seconds": 90,
      "slide_count": 1,
      "uses_scene": "slide-template",
      "voice": true,
      "notes": "Systemdiagramm. Komponenten und ihr Zusammenspiel."
    },
    {
      "section": "risk_layer",
      "order": 6,
      "target_seconds": 70,
      "min_seconds": 50,
      "max_seconds": 90,
      "slide_count": 1,
      "uses_scene": "slide-template",
      "voice": true,
      "accent_color_override": "#D9544E",
      "notes": "Risiken, Fehlerquellen, Grenzfaelle. Accent-Farbe Risk-Rot."
    },
    {
      "section": "protocol_example",
      "order": 7,
      "target_seconds": 80,
      "min_seconds": 60,
      "max_seconds": 110,
      "slide_count": 1,
      "uses_scene": "slide-template",
      "voice": true,
      "notes": "Konkretes Protokollbeispiel mit echtem Screenshot (z.B. Aave, Uniswap)."
    },
    {
      "section": "key_takeaways",
      "order": 8,
      "target_seconds": 50,
      "min_seconds": 35,
      "max_seconds": 70,
      "slide_count": 1,
      "uses_scene": "slide-template",
      "voice": true,
      "notes": "3-4 Kernaussagen. Zusammenfassung der Lektion."
    },
    {
      "section": "outro",
      "order": 9,
      "target_seconds": 12,
      "min_seconds": 8,
      "max_seconds": 15,
      "slide_count": 0,
      "uses_scene": "outro-scene",
      "voice": false,
      "notes": "Call to Action zur naechsten Lektion. Kein Hype-Voiceover."
    }
  ],

  "total_target_seconds": 474,

  "pacing_rules": {
    "seconds_per_bullet": 12,
    "min_visual_visibility_seconds": 8,
    "max_text_only_seconds": 10,
    "notes": "Jeder Bullet Point bekommt genug Sprechzeit. Visuals sind mindestens 8s sichtbar."
  },

  "cross_fade_between_sections_frames": 15,

  "lower_third_display": {
    "enabled": true,
    "sections": ["lesson_title", "concept", "protocol_example"],
    "duration_frames": 90,
    "fade_duration_frames": 15
  }
}
